+//------------------------------------------------------------------------------
+// Sinden Border Overlay (Option A): overwrite edge pixels inside active video
+//------------------------------------------------------------------------------
+module sinden_border_overlay #(
+    parameter int X_BITS = 12,
+    parameter int Y_BITS = 12
+)(
+    input  logic        clk,
+    input  logic        ce_pix,
+    input  logic        hs,
+    input  logic        vs,
+    input  logic        de_in,
+    input  logic [7:0]  r_in,
+    input  logic [7:0]  g_in,
+    input  logic [7:0]  b_in,
+
+    input  logic        border_en,
+    input  logic [3:0]  border_px,
+
+    output logic        de_out,
+    output logic [7:0]  r_out,
+    output logic [7:0]  g_out,
+    output logic [7:0]  b_out
+);
+
+    // Edge detect HS/VS rising edges
+    logic hs_d, vs_d;
+    always_ff @(posedge clk) if (ce_pix) begin
+        hs_d <= hs;
+        vs_d <= vs;
+    end
+    wire hs_rise =  hs & ~hs_d;
+    wire vs_rise =  vs & ~vs_d;
+
+    // Track x/y within active region
+    logic [X_BITS-1:0] x;
+    logic [Y_BITS-1:0] y;
+    logic [X_BITS-1:0] act_w;
+    logic [Y_BITS-1:0] act_h;
+
+    // DE falling edge to latch width and increment y
+    logic de_d;
+    always_ff @(posedge clk) if (ce_pix) de_d <= de_in;
+    wire de_fall = ~de_in & de_d;
+
+    always_ff @(posedge clk) if (ce_pix) begin
+        // New frame
+        if (vs_rise) begin
+            act_h <= y;
+            y     <= '0;
+        end
+
+        // New line
+        if (hs_rise) begin
+            x <= '0;
+        end else if (de_in) begin
+            x <= x + 1'd1;
+        end
+
+        // End of active line
+        if (de_fall) begin
+            act_w <= x;      // approximate active width
+            y     <= y + 1'd1;
+        end
+    end
+
+    // Avoid underflow before first measurement
+    wire [X_BITS-1:0] w = (act_w == '0) ? {X_BITS{1'b1}} : act_w;
+    wire [Y_BITS-1:0] h = (act_h == '0) ? {Y_BITS{1'b1}} : act_h;
+
+    wire in_border =
+        (x < border_px) ||
+        (x >= (w - border_px)) ||
+        (y < border_px) ||
+        (y >= (h - border_px));
+
+    always_comb begin
+        de_out = de_in;
+        if (border_en && de_in && in_border) begin
+            r_out = 8'hFF;
+            g_out = 8'hFF;
+            b_out = 8'hFF;
+        end else begin
+            r_out = r_in;
+            g_out = g_in;
+            b_out = b_in;
+        end
+    end
+endmodule
